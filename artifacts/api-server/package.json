{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node -e \"process.env.NODE_ENV='development'; require('child_process').spawnSync('pnpm', ['run', 'build'], { stdio: 'inherit', shell: true }); require('child_process').spawnSync('pnpm', ['run', 'start'], { stdio: 'inherit', shell: true });\"",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "dotenv": "^16.4.7",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "multer": "^2.2.0",
    "pdf-parse": "^1.1.1",
    "pino": "^9",
    "pino-http": "^10"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0"
  }
}
