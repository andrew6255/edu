# Optional external AI tutor provider.
# If AI_TUTOR_API_KEY is not set, the api-server uses deterministic fallback tutor logic.
AI_TUTOR_API_KEY=
AI_TUTOR_BASE_URL=https://api.openai.com/v1
AI_TUTOR_MODEL=gpt-4o-mini

# Alternative: OPENAI_API_KEY is also accepted if AI_TUTOR_API_KEY is empty.
OPENAI_API_KEY=
