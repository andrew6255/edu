rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public read for all uploaded program assets (MVP)
    match /programAssets/{allPaths=**} {
      allow read: if true;

      // Writes restricted to superadmins via custom auth claims.
      // You must set a custom claim on the user token, e.g. { role: "superadmin" }.
      allow write: if request.auth != null && request.auth.token.role == 'superadmin';
    }

    // Deny everything else by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
