rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────
    function isAuthed() {
      return request.auth != null;
    }

    function myUid() {
      return request.auth.uid;
    }

    function isOwn(userId) {
      return isAuthed() && myUid() == userId;
    }

    function myRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : 'student';
    }

    function isAdmin() {
      return isAuthed() && myRole() in ['admin', 'superadmin'];
    }

    function isSuperAdmin() {
      return isAuthed() && myRole() == 'superadmin';
    }

    function isTeacherOrAbove() {
      return isAuthed() && myRole() in ['teacher', 'admin', 'superadmin'];
    }

    // ── Users ─────────────────────────────────────────────────────────────
    // Any authenticated user may read any user doc (needed for leaderboard,
    // arena matchmaking, class/org membership checks).
    // Writes are own-uid only; admins/superadmin may write any user doc.
    match /users/{userId} {
      allow read: if true; // Public read required for username validation before login
      allow create: if isOwn(userId) || isAdmin();
      // Allow others to add themselves to a user's incomingRequests.
      // This is required for sending friend requests.
      allow update: if isOwn(userId) || isAdmin() || (
        isAuthed() &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['incomingRequests']) &&
        request.resource.data.incomingRequests is list &&
        (
          // Normal case: incomingRequests already exists
          (
            resource.data.incomingRequests is list &&
            request.resource.data.incomingRequests.size() == resource.data.incomingRequests.size() + 1 &&
            request.resource.data.incomingRequests.hasAll(resource.data.incomingRequests)
          )
          ||
          // Edge case: target user doc exists but incomingRequests is missing/null
          (
            !(resource.data.keys().hasAny(['incomingRequests'])) &&
            request.resource.data.incomingRequests.size() == 1
          )
        ) &&
        request.resource.data.incomingRequests.hasAny([myUid()])
      ) || (
        // Allow the receiver to remove their uid from the sender's outgoingRequests when responding.
        // (decline OR accept both require this cleanup)
        isAuthed() &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['outgoingRequests']) &&
        request.resource.data.outgoingRequests is list &&
        (
          (
            // Normal case: outgoingRequests exists and we remove exactly our uid
            resource.data.outgoingRequests is list &&
            resource.data.outgoingRequests.hasAny([myUid()]) &&
            request.resource.data.outgoingRequests.size() == resource.data.outgoingRequests.size() - 1 &&
            resource.data.outgoingRequests.hasAll(request.resource.data.outgoingRequests)
          )
          ||
          (
            // Edge case: outgoingRequests is missing/null, allow setting it to an empty list
            !(resource.data.keys().hasAny(['outgoingRequests'])) &&
            request.resource.data.outgoingRequests.size() == 0
          )
        )
      ) || (
        // Allow the receiver to add themselves to the sender's friends list when accepting.
        isAuthed() &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['friends']) &&
        request.resource.data.friends is list &&
        request.resource.data.friends.hasAny([myUid()]) &&
        (
          (
            // Normal case: friends exists and we add exactly our uid
            resource.data.friends is list &&
            request.resource.data.friends.size() == resource.data.friends.size() + 1 &&
            request.resource.data.friends.hasAll(resource.data.friends)
          )
          ||
          (
            // Edge case: friends is missing/null, allow setting it to a 1-item list containing our uid
            !(resource.data.keys().hasAny(['friends'])) &&
            request.resource.data.friends.size() == 1
          )
        )
      ) || (
        // Allow a user to unfriend: remove myUid from someone else's friends list.
        isAuthed() &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['friends']) &&
        request.resource.data.friends is list &&
        (
          (
            // Normal case: friends exists and we remove exactly our uid
            resource.data.friends is list &&
            resource.data.friends.hasAny([myUid()]) &&
            request.resource.data.friends.size() == resource.data.friends.size() - 1 &&
            resource.data.friends.hasAll(request.resource.data.friends)
          )
          ||
          (
            // Edge case: friends missing/null, allow setting it to empty list
            !(resource.data.keys().hasAny(['friends'])) &&
            request.resource.data.friends.size() == 0
          )
        )
      ) || (
        // Allow the receiver to accept a request in one atomic write on the sender:
        // remove myUid from outgoingRequests AND add myUid to friends.
        isAuthed() &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['outgoingRequests', 'friends']) &&
        request.resource.data.outgoingRequests is list &&
        request.resource.data.friends is list &&
        request.resource.data.friends.hasAny([myUid()]) &&
        (
          // outgoingRequests: normal removal OR edge case missing -> []
          (
            (
              resource.data.outgoingRequests is list &&
              resource.data.outgoingRequests.hasAny([myUid()]) &&
              request.resource.data.outgoingRequests.size() == resource.data.outgoingRequests.size() - 1 &&
              resource.data.outgoingRequests.hasAll(request.resource.data.outgoingRequests)
            )
            ||
            (
              !(resource.data.keys().hasAny(['outgoingRequests'])) &&
              request.resource.data.outgoingRequests.size() == 0
            )
          )
        ) &&
        (
          // friends: normal add OR edge case missing -> [myUid]
          (
            (
              resource.data.friends is list &&
              request.resource.data.friends.size() == resource.data.friends.size() + 1 &&
              request.resource.data.friends.hasAll(resource.data.friends)
            )
            ||
            (
              !(resource.data.keys().hasAny(['friends'])) &&
              request.resource.data.friends.size() == 1
            )
          )
        )
      );
      allow delete: if isAdmin();

      // Notifications inbox
      match /notifications/{notifId} {
        allow read: if isOwn(userId) || isAdmin();

        // Allow any authenticated user to create a notification for another user,
        // but require that the notification is attributed to the sender.
        allow create: if isAuthed() &&
          request.resource.data.fromUid == myUid() &&
          request.resource.data.id == notifId &&
          request.resource.data.type in ['friendRequest', 'challenge', 'system'];

        // Only the owner (or admin) can mark read / delete.
        allow update: if isOwn(userId) || isAdmin() || (
          // Allow the sender to update the notification they created (for de-dupe / bumping),
          // but only for a small safe set of fields.
          isAuthed() &&
          resource.data.fromUid == myUid() &&
          request.resource.data.fromUid == myUid() &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'message', 'createdAt', 'read', 'resolved', 'resolvedAt',
            'challengeId', 'gameId', 'gameLabel', 'type', 'id', 'fromUsername'
          ])
        );
        allow delete: if isOwn(userId) || isAdmin();
      }

      // Program map progress (per-user)
      match /program_progress/{programId} {
        allow read, write: if isOwn(userId) || isAdmin();
      }
    }

    // ── Organisations ─────────────────────────────────────────────────────
    // Any authenticated user can read orgs (for membership display, joining).
    // Only admins/superadmins can create/update/delete orgs.
    match /organisations/{orgId} {
      allow read: if isAuthed();
      allow create, update, delete: if isAdmin();
    }

    // ── Public Program Maps (Books) ───────────────────────────────────────
    // Any authenticated user can read the public programs catalog.
    // Only superadmins can create/update/delete.
    match /public_programs/{programId} {
      allow read: if isAuthed();
      allow create, update, delete: if isSuperAdmin();
    }

    // ── Classes ───────────────────────────────────────────────────────────
    // Any authenticated user can read class docs (for join-by-code flow).
    // Teachers and above can create/update/delete classes.
    match /classes/{classId} {
      allow read: if isAuthed();
      allow create, update, delete: if isTeacherOrAbove();
    }

    // ── Game Sessions ─────────────────────────────────────────────────────
    // Any authenticated user can read/write game sessions (arena gameplay).
    match /gameSessions/{sessionId} {
      allow read: if isAuthed();

      // Keep gameplay working as-is, but restrict writes to participants or admins.
      allow write: if isAuthed() && (
        isAdmin() ||
        resource == null ||
        resource.data.player1.uid == myUid() ||
        resource.data.player2.uid == myUid()
      );
    }

    // ── Matchmaking Queue ─────────────────────────────────────────────────
    match /matchmakingQueue/{entryId} {
      allow read, write: if isAuthed();
    }

    // ── Challenges ────────────────────────────────────────────────────────
    match /challenges/{challengeId} {
      allow read, write: if isAuthed();
    }

    // ── Program Friend Sessions (Program Map: Play a Friend) ─────────────
    // Join codes are the document IDs, so clients join via getDoc (no query).
    // Security model:
    // - deny list (prevents discovery)
    // - allow get for authed users (needed to join by code)
    // - writes restricted to participants/admins
    match /programFriendSessions/{sessionId} {
      allow list: if false;
      allow get: if isAuthed();

      allow create: if isAuthed() && (
        isAdmin() ||
        request.resource.data.host.uid == myUid()
      );

      allow update, delete: if isAuthed() && (
        isAdmin() ||
        resource.data.host.uid == myUid() ||
        (resource.data.guest != null && resource.data.guest.uid == myUid())
      );
    }

    // ── Leaderboards (mini-game high-score aggregates) ────────────────────
    match /leaderboards/{gameId} {
      allow read: if isAuthed();
      allow write: if isAuthed();
    }

    // ── Curriculum Requests ───────────────────────────────────────────────
    // Students can create and read their own requests.
    // Admins/superadmins can read and update all requests.
    match /curriculumRequests/{reqId} {
      allow create: if isAuthed();
      allow read: if isAuthed() && (
        resource.data.uid == myUid() || isAdmin()
      );
      allow update, delete: if isAdmin();
    }

  }
}
